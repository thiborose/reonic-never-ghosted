# Never Ghosted — root env template.
# Copy to .env and fill in:  cp .env.template .env
# .env is gitignored. Never commit real keys.

# ── OpenAI (powers both the engine and the basic pydantic-ai agent) ───────────
OPENAI_API_KEY=
# Optional: custom endpoint / proxy. Leave blank for api.openai.com.
# OPENAI_BASE_URL=

# ── Models ────────────────────────────────────────────────────────────────────
# Basic agent (backend/app/agent) — pydantic-ai model id.
NG_AGENT_MODEL=openai-responses:gpt-4o
# Engine A judge/strategy model (used by ab_compare.py + engine/llm.py).
ENGINE_MODEL=gpt-4o-2024-08-06

# ── Service ports (copy as-is; these match docker-compose + the dev servers) ──
# Postgres (backend/docker-compose.yml maps host 5433 -> container 5432).
POSTGRES_PORT=5433
NG_DATABASE_URL=postgresql+psycopg://ng:ng@localhost:5433/never_ghosted
# Backend FastAPI (uvicorn).
API_PORT=8000
# Frontend (next dev).
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
