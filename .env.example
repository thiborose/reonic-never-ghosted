# Copy to .env and fill in. Shared by the VoltAgent service and the backend.

# Required: the LLM key the VoltAgent agent (and the Python fallback engine) use.
# This root .env is the single source of keys — the agent loads it (../../.env in
# dev, env_file in docker) and the backend reads it via env_file. Don't put keys
# anywhere else.
OPENAI_API_KEY=PUT-YOUR-OWN-OPENAI-KEY-HERE

# --- Optional overrides (sensible defaults baked into docker-compose) ---

# Model the agent uses for strategy synthesis. With OPENAI_API_KEY this must be a
# bare OpenAI model id (e.g. gpt-5-mini, gpt-4o-mini) — NOT prefixed. The default
# "openai/gpt-5-mini" carries an OpenRouter-style prefix that the agent strips
# automatically when talking to OpenAI directly; only keep the prefix for OpenRouter.
# VOLTAGENT_MODEL=gpt-5-mini

# Which engine writes plans by default: voltagent (primary) | python | fake.
# The frontend dropdown overrides this per-request.
# NG_ENGINE=voltagent

# Where the backend reaches the VoltAgent service. In compose this is the service
# name; running the three processes by hand it's localhost.
# REONIC_AGENT_URL=http://localhost:3141

# Set to "true" to fail loudly if VoltAgent is unreachable instead of falling back
# to the deterministic engine. Leave unset for demos.
# REONIC_AGENT_STRICT=false

# Backend database. Defaults to the compose Postgres; override for a local one.
# NG_DATABASE_URL=postgresql+psycopg://ng:ng@localhost:5434/never_ghosted

# Frontend API base, baked into the browser bundle at build time.
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Host port overrides (defaults shown).
# POSTGRES_PORT=5434
# AGENT_PORT=3141
# API_PORT=8000
# FRONTEND_PORT=3000
