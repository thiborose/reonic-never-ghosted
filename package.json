{
  "name": "reonic-platform-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--no-warnings tsx server/index.ts",
    "start": "NODE_ENV=production NODE_OPTIONS=--no-warnings tsx server/index.ts",
    "agent:start": "cd agent && npm run start",
    "agent:dev": "cd agent && npm run dev",
    "agent:smoke": "NODE_OPTIONS=--no-warnings tsx scripts/agent-smoke.ts",
    "ui:smoke": "NODE_OPTIONS=--no-warnings tsx scripts/ui-smoke.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--no-warnings vitest run",
    "db:reset": "NODE_OPTIONS=--no-warnings tsx server/reset-db.ts"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.10.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.1.0"
  }
}
