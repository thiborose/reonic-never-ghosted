# Copy to .env and fill in. The backend reads config from the environment.

# OpenAI key for the pydantic-ai agent (app/agent). Read by pydantic-ai directly.
OPENAI_API_KEY=

# Logfire write token (token method, no `logfire auth` needed). Create one in the
# Logfire UI → project → Settings → Write tokens. When set, agent runs are traced;
# when empty, send_to_logfire="if-token-present" makes Logfire a no-op.
LOGFIRE_TOKEN=

# Optional: override the agent model (default: openai-responses:gpt-4o).
# NG_AGENT_MODEL=openai-responses:gpt-4o

# Optional: Postgres DSN (default points at the local docker-compose db).
# NG_DATABASE_URL=postgresql+psycopg://ng:ng@localhost:5433/never_ghosted
